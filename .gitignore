# --- bundled binaries (downloaded by installer, not tracked) ---
n8n-student-kit/tools/*.exe
n8n-student-kit/tools/images/

# --- logs ---
*.log

# --- OS / editor noise ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

.vs/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# --- misc ---
node_modules/
dist/
build/
*.tmp
*.bak
*.stackdump
